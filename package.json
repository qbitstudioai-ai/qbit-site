{
  "name": "qbit-site",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && node scripts/prerender.mjs",
    "lint": "eslint .",
    "preview": "vite preview",
    "generate-favicon": "node scripts/generate-favicon-png.mjs",
    "optimize:raster-icons": "node scripts/convert-embedded-svg-to-webp.mjs",
    "optimize:automation-icons": "node scripts/convert-automation-example-icons.mjs",
    "trim:webp-icons": "node scripts/trim-webp-icons.mjs",
    "supabase": "supabase",
    "supabase:version": "supabase --version",
    "supabase:deploy:analytics-session": "supabase functions deploy qbit-analytics-session --no-verify-jwt",
    "supabase:deploy:upload-site-asset": "supabase functions deploy upload-site-asset --no-verify-jwt",
    "supabase:deploy:save-site-copy": "supabase functions deploy save-site-copy --no-verify-jwt",
    "supabase:deploy:serve-privacy-html": "supabase functions deploy serve-privacy-html --no-verify-jwt"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.102.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "puppeteer": "^24.43.1",
    "sharp": "^0.34.5",
    "supabase": "^2.88.1",
    "to-ico": "^1.1.5",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.4"
  }
}

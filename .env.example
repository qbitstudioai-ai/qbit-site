# Скопируйте в .env и задайте значения (файл .env не коммитится)
# Публичный URL без слэша в конце (canonical, Open Graph). По умолчанию при сборке: https://allqbit.ru
VITE_SITE_URL=https://allqbit.ru

# Supabase PostgREST (аналитика qbit_site). URL без завершающего слэша.
VITE_SUPABASE_URL=https://supabase.allqbit.ru
VITE_SUPABASE_ANON_KEY=

# Логин и пароль админки (#/admin); в проде задайте свои значения
VITE_ADMIN_LOGIN=
VITE_ADMIN_PASSWORD=

# На сервере (env контейнера Edge Functions), тот же пароль что VITE_ADMIN_PASSWORD — для загрузки презентации/политики в Storage:
# QBIT_ADMIN_UPLOAD_PASSWORD=
